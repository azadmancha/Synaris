# Development environment configuration
# Copy this file to .env and fill in real secrets before running Synaris.

# PostgreSQL connection string for the API service.
DATABASE_URL=postgresql+asyncpg://synaris:synaris@localhost:5432/synaris

# Shared authentication secret used by frontend Auth.js and backend JWT validation.
AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth credentials for Auth.js / Google provider.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Next.js Auth.js configuration.
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional cookie configuration.
COOKIE_DOMAIN=localhost

# Backend settings.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
