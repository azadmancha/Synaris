# Development environment configuration
# Copy this file to .env and fill in real secrets before running Synaris.

# PostgreSQL connection string for the API service.
DATABASE_URL=postgresql+asyncpg://synaris:synaris@localhost:5432/synaris

# Shared authentication secret used by frontend Auth.js and backend JWT validation.
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_SECRET=${AUTH_SECRET}

# Google OAuth credentials for Auth.js / Google provider.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI provider credentials.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=gpt-4o-mini
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=groq-1.5-mini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-mini

# Application configuration.
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
COOKIE_DOMAIN=localhost
APP_URL=http://localhost:3000

# Backend settings.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
